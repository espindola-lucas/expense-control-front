# ── Mode ───────────────────────────────────────────────────────────────────
# "dev" → hot-reload dev server   |   "prod" → nginx serving the built bundle
COMPOSE_PROFILES=dev

# ── App secrets ────────────────────────────────────────────────────────────
APP_URL=

# ── API ─────────────────────────────────────────────────────────────────────
# Set to your machine's local IP when testing from a phone or another device.
# Example: VITE_API_URL=http://IP/api
VITE_API_URL=